{
  "name": "autopilot",
  "description": "End-to-end workflow: research → analyze → write → review → loop. Adopted from oh-my-codex autopilot pattern.",
  "steps": [
    {
      "skill": "/second-claude-code:research",
      "args": "\"{{topic}}\" --depth medium",
      "output": "research-brief.md",
      "on_fail": "abort"
    },
    {
      "skill": "/second-claude-code:analyze",
      "args": "--framework prd --with-research",
      "input_from": "research-brief.md",
      "output": "analysis.md",
      "on_fail": "abort"
    },
    {
      "skill": "/second-claude-code:write",
      "args": "",
      "input_from": "analysis.md",
      "output": "draft.md",
      "on_fail": "abort"
    },
    {
      "skill": "/second-claude-code:review",
      "args": "--preset content",
      "input_from": "draft.md",
      "output": "review-report.md",
      "on_fail": "abort"
    },
    {
      "skill": "/second-claude-code:loop",
      "args": "--max 3 --target APPROVED",
      "input_from": ["draft.md", "review-report.md"],
      "output": "final.md",
      "on_fail": "retry"
    }
  ]
}
