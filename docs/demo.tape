# Second Claude Code — Demo Recording
# Run with: vhs docs/demo.tape
# Requires: vhs (brew install charmbracelet/tap/vhs)

Output docs/images/demo.gif
Set FontSize 14
Set Width 800
Set Height 400
Set Theme "Catppuccin Mocha"
Set Padding 20
Set TypingSpeed 50ms

# Start Claude Code
Type "claude"
Enter
Sleep 2s

# Show auto-routing with natural language
Type "Write an article about AI agents in 2026"
Sleep 1s
Enter
Sleep 3s

# Show the auto-route detection
Type "# Auto-routed to /second-claude-code:write"
Sleep 2s
